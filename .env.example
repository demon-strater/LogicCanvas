PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://username:password@localhost:5432/pasted_logic
OPENAI_API_KEY=sk-your-openai-api-key

# Optional fallback for a single workspace/internal connection.
NOTION_API_KEY=secret_your-notion-token

# Preferred for user-facing "Connect Notion" without asking users for API keys.
# Create a public Notion connection and set its redirect URI to:
# http://127.0.0.1:5000/api/notion/oauth/callback
NOTION_OAUTH_CLIENT_ID=your-notion-oauth-client-id
NOTION_OAUTH_CLIENT_SECRET=your-notion-oauth-client-secret
NOTION_OAUTH_REDIRECT_URI=http://127.0.0.1:5000/api/notion/oauth/callback
PUBLIC_URL=http://127.0.0.1:5000
SESSION_SECRET=replace-with-a-long-random-string
COOKIE_SECURE=false
